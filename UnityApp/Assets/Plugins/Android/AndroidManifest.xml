<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.sentientx.datacapture">

    <!-- Standard Android permissions -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.HIGH_SAMPLING_RATE_SENSORS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- PICO-specific permissions -->
    <uses-permission android:name="com.picovr.screencapture.permission.SHOT_AND_RECORD" />
    <uses-permission android:name="com.picovr.permission.HAND_TRACKING" />
    <uses-permission android:name="com.picovr.permission.BODY_TRACKING" />
    <uses-permission android:name="com.picovr.permission.SPATIAL_DATA" />
    <uses-permission android:name="com.picoxr.permission.HAND_TRACKING" />
    <uses-permission android:name="com.picoxr.permission.BODY_TRACKING" />
    <uses-permission android:name="com.picoxr.permission.SPATIAL_DATA" />
    <uses-feature android:name="android.hardware.vr.headtracking" android:required="true" android:version="1" />

    <!-- PICO hand tracking: allows app to run without controllers -->
    <uses-feature android:name="picoxr.software.handtracking" android:required="false" />
    <uses-feature android:name="wave.feature.handtracking" android:required="false" />

    <application
        android:requestLegacyExternalStorage="true">

        <service
            android:name="com.sentientx.datacapture.ScreenRecorderService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <activity
            android:name="com.sentientx.datacapture.CaptureUnityPlayerActivity"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:hardwareAccelerated="true"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:launchMode="singleTask"
            android:resizeableActivity="false"
            android:screenOrientation="landscape"
            android:exported="true"
            tools:replace="android:hardwareAccelerated,android:screenOrientation">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="com.pico.intent.category.VRAPP" />
            </intent-filter>

            <meta-data android:name="unityplayer.UnityActivity" android:value="true" />
        </activity>

        <receiver
            android:name="com.sentientx.datacapture.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.sentientx.datacapture.RemoteCommandReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="com.sentientx.datacapture.CMD" />
            </intent-filter>
        </receiver>

        <!-- Camera permission request activity from questcameralib.aar -->
        <activity
            android:name="com.samusynth.questcamera.core.CameraPermissionRequestActivity"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:exported="false" />

        <meta-data android:name="pvr.app.type" android:value="vr" />
        <meta-data android:name="pvr.sdk.version" android:value="PICO Unity Integration SDK" />
        <meta-data android:name="enable_vst" android:value="1" />
        <meta-data android:name="enable_mr" android:value="1" />
        <!-- handtracking/controller metadata intentionally omitted here.
             HandTrackingManifestPostProcessor removes these at build time to prevent
             startup hangs on Pico 4 Ultra firmware. -->
    </application>
</manifest>
